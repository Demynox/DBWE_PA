[Unit]
Description=Scootermania Flask App
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/scootermania
EnvironmentFile=/var/www/scootermania/.env
ExecStart=/var/www/scootermania/.venv/bin/gunicorn -c deploy/gunicorn.conf.py wsgi:app
Restart=always

[Install]
WantedBy=multi-user.target
